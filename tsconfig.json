{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
   
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "es2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "lib": ["esnext"],
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "skipLibCheck": true,
    
    "verbatimModuleSyntax": false,
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}